</script><section class="block map-block" style="padding:3rem 1.5rem"><div style="max-width:1200px;margin:0 auto"><h2 style="margin-bottom:.8rem;font-weight:700">Location and service area</h2><p style="margin-bottom:1rem;color:#555">We serve projects across Sunshine Coast.</p><div class="map-wrap" style="position:relative;max-width:520px;margin:0 auto;aspect-ratio:4/3;border-radius:8px;overflow:hidden;border:1px solid #E5E7EB"><div id="map_fe6671_c6b9" style="position:absolute;top:0;left:0;width:100%;height:100%"></div></div><script>
