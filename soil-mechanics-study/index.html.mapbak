attribution:"&copy; OpenStreetMap contributors &copy; CARTO",maxZoom:19,subdomains:"abcd"
}).addTo(m);
L.marker([-26.6544338,153.0933668],{icon:L.divIcon({html:'<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 36\" width=\"24\" height=\"36\"><path d=\"M12 0C5.4 0 0 5.4 0 12c0 9 12 24 12 24s12-15 12-24c0-6.6-5.4-12-12-12z\" fill=\"#E11D48\" stroke=\"#FFF\" stroke-width=\"1.5\"/><circle cx=\"12\" cy=\"12\" r=\"4\" fill=\"#FFF\"/></svg>',className:'',iconSize:[24,36],iconAnchor:[12,36],popupAnchor:[0,-32]})}).addTo(m).bindPopup("Sunshine Coast");
})();
</script><div style="margin-top:.5rem;font-size:.78rem;color:#888;text-align:center">Location and service area</div></div></section><footer style="background:#0F172A;color:rgba(255,255,255,.85);padding:3rem 1.5rem 1.5rem"><div style="max-width:720px;margin:0 auto;text-align:center"><p style="margin:1.5rem 0 0;font-size:.82rem;color:rgba(255,255,255,.5)">Sunshine Coast, Australia · <a href="mailto:contact@geotechnicalengineering1.xyz" style="color:rgba(255,255,255,.7)">contact@geotechnicalengineering1.xyz</a> · © 2026</p></div><div data-updated="2026-03-25" style="font-size:.78rem;color:rgba(255,255,255,.6);margin-top:.8rem">Last updated: 2026-03-25</div><div data-authority-refs class="authority-refs" style="text-align:center;font-size:.8rem;padding:.5rem 0;opacity:.6"><strong>References:</strong>ASTM Standards · USACE Engineer Manuals · ISO Geotechnical</div></footer><script>(function(){
// Dropdown click toggle
document.querySelectorAll(".nav-item.has-dd .nav-arrow").forEach(function(b){
b.addEventListener("click",function(e){
e.preventDefault();e.stopPropagation();
var p=b.parentElement;
var wasOpen=p.classList.contains("open");
document.querySelectorAll(".nav-item.has-dd.open").forEach(function(o){o.classList.remove("open");});
if(!wasOpen)p.classList.add("open");
});
});
document.addEventListener("click",function(e){
if(!e.target.closest(".nav-item.has-dd"))document.querySelectorAll(".nav-item.has-dd.open").forEach(function(o){o.classList.remove("open");});
});
// CONTATO clipboard copy
document.querySelectorAll(".cta-btn[data-email]").forEach(function(b){
b.addEventListener("click",function(e){
e.preventDefault();
var em=b.getAttribute("data-email");
navigator.clipboard.writeText(em).then(function(){
var orig=b.textContent;
b.textContent="Email copied";
b.style.background="#16A34A";
setTimeout(function(){b.textContent=orig;b.style.background="";},2000);
});
});
});
})();</script></body></html>